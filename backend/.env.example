# =============================================
# MycoMart Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/mycomart
# For Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/mycomart

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=30d

# Pagination defaults
RESULTS_PER_PAGE=12
